{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn",
    "style": "warn"
  },
  "rules": {},
  "env": {
    "builtin": true
  },
  "settings": {
    "oxc/tsconfig": "./tsconfig.json"
  }
}
