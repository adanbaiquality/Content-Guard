{
  "name": "@content-guard/workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n plugin,api -c cyan,magenta \"pnpm --filter @content-guard/storyblok-plugin dev\" \"pnpm --filter @content-guard/api dev\"",
    "dev:plugin": "pnpm --filter @content-guard/storyblok-plugin dev",
    "dev:api": "pnpm --filter @content-guard/api dev",
    "dev:api:tunnel": "concurrently -n api,tunnel -c magenta,green \"pnpm --filter @content-guard/api dev\" \"pnpm tunnel\"",
    "build": "pnpm --filter @content-guard/storyblok-plugin build && pnpm --filter @content-guard/api build",
    "build:plugin": "pnpm --filter @content-guard/storyblok-plugin build",
    "build:api": "pnpm --filter @content-guard/api build",
    "tunnel": "devtunnel host",
    "lint": "oxlint --type-aware",
    "lint:check": "oxlint --deny-warnings --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "typecheck": "pnpm --filter @content-guard/storyblok-plugin typecheck && pnpm --filter @content-guard/api typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0"
  },
  "engines": {
    "node": "24",
    "pnpm": "11"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
