# Workflow SDK target world configuration
# Local development works with no configuration.
# Optional: explicitly force local world.
# WORKFLOW_TARGET_WORLD=local
# Optional: SQLite path for Content Guard local persistence
# (run cache + output snapshots).
# CONTENT_GUARD_DB_PATH=.workflow-data/content-guard.db
# For self-hosted Postgres world, set the following:
# WORKFLOW_TARGET_WORLD=@workflow/world-postgres
# WORKFLOW_POSTGRES_URL=postgres://user:password@host:5432/database
NEXT_PUBLIC_STORYBLOK_ACCESS_TOKEN=
STORYBLOK_PAT=
